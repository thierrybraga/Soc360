# =============================================================================
# Open-Monitor v3.0 - Environment Configuration Template
# Copy this file to .env and configure your values
# NEVER commit .env to version control - add it to .gitignore
# =============================================================================

# =============================================================================
# 🔐 CORE SECURITY (REQUIRED - Generate strong values)
# =============================================================================
# Flask secret key - CRITICAL for session security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Application environment: production | development | staging
FLASK_ENV=production

# Debug mode: 0 = disabled (production), 1 = enabled (development ONLY)
# ⚠️ Never enable in production - exposes sensitive information
FLASK_DEBUG=0

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# 🗄️ DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL credentials (shared for both databases)
POSTGRES_USER=openmonitor
POSTGRES_PASSWORD=

# Core Database: Users, Assets, Rules, Reports, Audit Logs
POSTGRES_CORE_DB=openmonitor_core

# Public Database: CVE/NVD data (read-optimized, can be replicated)
POSTGRES_PUBLIC_DB=openmonitor_public

# Optional: Expose database ports externally (leave empty in production)
# Format: "5432" to expose, or "" to keep internal only
DB_CORE_EXPOSE=
DB_PUBLIC_EXPOSE=

# =============================================================================
# 🗃️ REDIS CONFIGURATION (Cache, Queue, Sessions)
# =============================================================================
# Redis password - Leave empty for no auth (NOT recommended for production)
REDIS_PASSWORD=

# Redis database indexes (0-15)
REDIS_DB_SESSIONS=0
REDIS_DB_CELERY_BROKER=1
REDIS_DB_CELERY_RESULT=2
REDIS_DB_RATE_LIMIT=3

# =============================================================================
# 🔗 EXTERNAL API INTEGRATIONS
# =============================================================================
# NVD API Key (Optional but HIGHLY recommended)
# Without key: 5 requests/30s | With key: 50 requests/30s
# Request at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# AI Provider: openai (padrão) | ollama (LLM local, requer docker-compose.ollama.yml)
# - openai sem OPENAI_API_KEY: modo demo com respostas simuladas
# - openai com OPENAI_API_KEY: respostas reais via API OpenAI
AI_PROVIDER=openai

# OpenAI API Key (recomendado — sem chave o chatbot opera em modo demo)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (apenas se AI_PROVIDER=ollama e usando docker-compose.ollama.yml)
# OLLAMA_MODEL=gemma4:e4b
# OLLAMA_NUM_THREADS=4
# CPU_LIMIT=4
# MEMORY_LIMIT=32G
# MEMORY_RESERVE=16G

# Cisco Umbrella API Configuration
# Get API credentials at: https://developer.cisco.com/docs/umbrella/
# Set UMBRELLA_USE_MOCK=true to use demo data without real API
UMBRELLA_USE_MOCK=true
UMBRELLA_API_KEY=
UMBRELLA_API_SECRET=

# =============================================================================
# 📧 EMAIL / SMTP CONFIGURATION (For alerts and notifications)
# =============================================================================
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@openmonitor.local
MAIL_SUPPRESS_SEND=false  # Set true to log emails instead of sending (dev)

# =============================================================================
# 🔒 SECURITY HARDENING
# =============================================================================
# Cookie security - MUST be true in production with HTTPS
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# CSRF protection
CSRF_ENABLED=true

# Preferred URL scheme for redirects (https in production)
PREFERRED_URL_SCHEME=https

# Rate limiting (requests per minute per IP)
RATELIMIT_DEFAULT=60
RATELIMIT_STORAGE_URI=redis://:REDIS_PASSWORD@redis:6379/3

# =============================================================================
# 🌐 NETWORK & SERVER
# =============================================================================
# Host and port for the application (internal container network)
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000

# External ports exposed by NGINX reverse proxy
HTTP_PORT=80
HTTPS_PORT=443

# =============================================================================
# ⚙️ APPLICATION SCALING & PERFORMANCE
# =============================================================================
# Gunicorn workers: 2x-4x CPU cores recommended
WORKERS=4

# Threads per worker (gthread class)
THREADS=2

# Request timeout in seconds
GUNICORN_TIMEOUT=120

# Celery worker concurrency
CELERY_WORKERS=2

# Max memory for Redis (prevents OOM)
REDIS_MAXMEMORY=512mb

# =============================================================================
# 📊 OBSERVABILITY & MONITORING
# =============================================================================
# Structured logging format: json | console
STRUCTLOG_RENDERER=json

# Health check endpoint path
HEALTH_CHECK_PATH=/health

# =============================================================================
# 🧪 DEVELOPMENT OVERRIDES (Ignored in production)
# =============================================================================
# Enable Flask reloader for hot-reload (dev only)
FLASK_RELOAD=false

# Allow CORS for specific origins (dev only)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8080

# =============================================================================
# 🚀 DEPLOYMENT HELPERS
# =============================================================================
# Database URLs are auto-constructed in docker-compose.yml
# Manual override (only if not using compose):
# CORE_DATABASE_URL=postgresql://user:pass@db-core:5432/openmonitor_core
# PUBLIC_DATABASE_URL=postgresql://user:pass@db-public:5432/openmonitor_public
# REDIS_URL=redis://:password@redis:6379/0
# CELERY_BROKER_URL=redis://:password@redis:6379/1