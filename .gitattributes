# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Force LF for entrypoint specifically
infra/docker/entrypoint.sh text eol=lf

# Docker files should also use LF
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Python files
*.py text eol=lf

# Powershell files (CRLF is acceptable but LF is preferred)
*.ps1 text eol=lf