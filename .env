# =============================================================================
# Open-Monitor v3.0 - Environment Configuration
# =============================================================================
# IMPORTANT: Secrets are loaded from ./secrets/ directory
#    - secret_key.txt: Flask SECRET_KEY
#    - redis_password.txt: Redis password
#    - db_password.txt: Database password (if using PostgreSQL)
# Edit these files with secure values before deployment
# NEVER commit secrets/ to version control
# =============================================================================

# =============================================================================
# Flask Configuration
# =============================================================================
FLASK_ENV=development
FLASK_DEBUG=1
LOG_LEVEL=WARNING

# =============================================================================
# Ports
# =============================================================================
HTTP_PORT=80
HTTPS_PORT=443
AIRFLOW_PORT=8080
OLLAMA_PORT=11434

# =============================================================================
# NVD API Configuration
# =============================================================================
# Optional: Get an API key from https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=26b62f85-2c9d-4194-8739-ecb4aa1a35c1

# =============================================================================
# AI Provider Configuration
# =============================================================================
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b
OLLAMA_MAX_TOKENS=4096
OLLAMA_TEMPERATURE=0.8
OPENAI_API_KEY=

# =============================================================================
# Email Configuration (Optional - for alerts)
# =============================================================================
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@soc360.local

# =============================================================================
# App Workers
# =============================================================================
WORKERS=2
THREADS=2
CELERY_WORKERS=2

# =============================================================================
# Ollama Resources (qwen3.6:35b precisa de ~24GB)
# =============================================================================
CPU_LIMIT=4
MEMORY_LIMIT=32G
CPU_RESERVE=2
MEMORY_RESERVE=16G
OLLAMA_NUM_THREADS=4
OLLAMA_NUM_PARALLEL=1
SECRET_KEY=soc360-preview-dev-key-1776723548
