# Open-Monitor v3.0 - Environment Configuration
# Copy this file to .env and configure your values

# =============================================================================
# Flask Configuration
# =============================================================================
FLASK_ENV=production
FLASK_DEBUG=0
LOG_LEVEL=INFO

# CRITICAL: Generate a strong secret key
# Use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=openmonitor
POSTGRES_PASSWORD=change-this-to-a-secure-password
POSTGRES_CORE_DB=openmonitor_core
POSTGRES_PUBLIC_DB=openmonitor_public

# =============================================================================
# Redis Configuration
# =============================================================================
# Leave empty for no password, or set a secure password
REDIS_PASSWORD=

# =============================================================================
# NVD API Configuration
# =============================================================================
# Optional: Get an API key from https://nvd.nist.gov/developers/request-an-api-key
# Without a key: 5 requests per 30 seconds
# With a key: 50 requests per 30 seconds
NVD_API_KEY=

# =============================================================================
# OpenAI Configuration (Optional - for AI-powered reports)
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# Email Configuration (Optional - for alerts)
# =============================================================================
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@openmonitor.local

# =============================================================================
# Security Settings
# =============================================================================
SESSION_COOKIE_SECURE=true
CSRF_ENABLED=true

# =============================================================================
# Network Ports
# =============================================================================
HTTP_PORT=80
HTTPS_PORT=443

# =============================================================================
# Application Scaling
# =============================================================================
WORKERS=4
THREADS=2
