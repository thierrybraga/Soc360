# Open-Monitor v3.0 - Environment Configuration
# Copy this file to .env and configure your values

# =============================================================================
# Flask Configuration
# =============================================================================
FLASK_ENV=development
FLASK_DEBUG=0
LOG_LEVEL=INFO

# CRITICAL: Generate a strong secret key
# Use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=5e09c1055625cb9453fbe9497f0ab57e3702ce8d3a60c00a579dd71ff5ad30c7

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=openmonitor
POSTGRES_PASSWORD=50b266f6c458e4e649651a15489ac06b
POSTGRES_CORE_DB=openmonitor_core
POSTGRES_PUBLIC_DB=openmonitor_public

# =============================================================================
# Redis Configuration
# =============================================================================
# Leave empty for no password, or set a secure password
REDIS_PASSWORD=

# =============================================================================
# NVD API Configuration
# =============================================================================
# Optional: Get an API key from https://nvd.nist.gov/developers/request-an-api-key
# Without a key: 5 requests per 30 seconds
# With a key: 50 requests per 30 seconds
NVD_API_KEY=

# =============================================================================
# AI Provider Configuration
# =============================================================================
# Provedor ativo: 'ollama' (local, padrão) | 'openai'
AI_PROVIDER=ollama

# Ollama — servidor local (https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:latest
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.7

# OpenAI — cloud (opcional, só usado se AI_PROVIDER=openai)
OPENAI_API_KEY=

# =============================================================================
# Email Configuration (Optional - for alerts)
# =============================================================================
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@openmonitor.local
POSTGRES_USER=openmonitor
POSTGRES_PASSWORD=password
POSTGRES_CORE_DB=openmonitor_core
POSTGRES_PUBLIC_DB=openmonitor_public

# App Settings (Mapped for BaseConfig)
DB_CORE_HOST=localhost
DB_CORE_PORT=5432
DB_CORE_NAME=openmonitor_core
DB_CORE_USER=openmonitor
DB_CORE_PASSWORD=password

DB_PUBLIC_HOST=localhost
DB_PUBLIC_PORT=5433
DB_PUBLIC_NAME=openmonitor_public
DB_PUBLIC_USER=openmonitor
DB_PUBLIC_PASSWORD=password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password

# NVD API Configuration (Optional)
NVD_API_KEY=b116e2c1-df02-47c3-a5c9-9cc7e23be8ed

# OpenAI Configuration (Optional — ativo apenas quando AI_PROVIDER=openai)
OPENAI_API_KEY=
