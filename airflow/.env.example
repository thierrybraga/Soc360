# Airflow environment — copie para airflow/.env e configure
# Usado pelo overlay docker-compose.airflow.yml

# Chave de criptografia Fernet (obrigatório em produção)
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# Usuário admin do Airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=admin@soc360.local

# Executor (LocalExecutor para stack single-node)
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Porta da UI Airflow (default: 8080)
AIRFLOW_PORT=8080
